# Local (Docker Compose)
MYSQL_DATABASE=aidom
MYSQL_USER=aidomuser
MYSQL_PASSWORD=aidomsecret
MYSQL_ROOT_PASSWORD=aidomverysecret
# JWT configuration
JWT_SECRET=REPLACE_WITH_BASE64_SECRET_MIN_32_BYTES
# OAuth2 configuration
AUTH_SUCCESS_URI=http://localhost:3000/auth/callback
AUTH_REDIRECT_URIS=http://localhost:3000/auth/callback
AUTH_ALLOWED_ORIGINS=http://localhost:3000
# Kakao OAuth2 configuration
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8090/login/oauth2/code/kakao

# Production (RDS) - GitHub Secrets로 관리
# DB_URL=jdbc:mysql://<rds-endpoint>.ap-northeast-2.rds.amazonaws.com:3306/aidom
# DB_USERNAME=aidomuser
# DB_PASSWORD=<rds-password>
